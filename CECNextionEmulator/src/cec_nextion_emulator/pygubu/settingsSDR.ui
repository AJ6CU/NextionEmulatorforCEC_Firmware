<?xml version='1.0' encoding='utf-8'?>
<interface version="1.5" author="PygubuDesigner 0.41.4">
  <project>
    <settings>
      <setting id="name">settingsSDR</setting>
      <setting id="description">Used to save of machines</setting>
      <setting id="template">widget</setting>
      <setting id="main_widget">settingsSDR_Labelframe</setting>
      <setting id="module_namespace" />
      <setting id="module_name">settingsSDR</setting>
      <setting id="main_classname">settingsSDR</setting>
      <setting id="output_dir">..</setting>
      <setting id="builder_namespace">custom_widgets</setting>
      <setting id="output_dir2">..</setting>
      <setting id="generate_code_onsave">False</setting>
      <setting id="use_i18n">False</setting>
      <setting id="all_ids_attributes">False</setting>
      <setting id="import_tkvariables">False</setting>
      <setting id="use_ttk_styledefinition_file">True</setting>
      <setting id="use_window_centering_code">False</setting>
      <setting id="ttk_style_definition_file">../mystyles.py</setting>
    </settings>
    <customwidgets />
    <resources />
  </project>
  <object class="tk.Toplevel" id="settings_Window" named="True">
    <property name="title" translatable="yes">Machine Settings</property>
    <child>
      <object class="ttk.Labelframe" id="settingsSDR_Labelframe" named="True">
        <property name="cursor">arrow</property>
        <property name="style">Heading2.TLabelframe</property>
        <property name="text" translatable="yes">SDR Settings </property>
        <layout manager="pack">
          <property name="expand">true</property>
          <property name="fill">both</property>
          <property name="side">top</property>
        </layout>
        <child>
          <object class="ttk.Frame" id="frame1">
            <property name="height">200</property>
            <property name="style">Normal.TFrame</property>
            <property name="width">200</property>
            <layout manager="pack">
              <property name="anchor">center</property>
              <property name="expand">true</property>
              <property name="fill">both</property>
              <property name="padx">10</property>
              <property name="pady">10</property>
              <property name="side">top</property>
            </layout>
            <child>
              <object class="ttk.Frame" id="SDR_Frame" named="True">
                <property name="height">200</property>
                <property name="style">NormalOutline.TFrame</property>
                <property name="width">200</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="columnspan">2</property>
                  <property name="row">0</property>
                  <property name="sticky">ew</property>
                </layout>
                <child>
                  <object class="ttk.Frame" id="enableSDR_Frame" named="True">
                    <property name="height">200</property>
                    <property name="style">Normal.TFrame</property>
                    <property name="width">200</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="columnspan">2</property>
                      <property name="padx">10</property>
                      <property name="pady">10</property>
                      <property name="row">0</property>
                      <property name="sticky">ew</property>
                    </layout>
                    <child>
                      <object class="ttk.Label" id="SDR_Enable_Label" named="True">
                        <property name="state">disabled</property>
                        <property name="style">Heading1b.TLabel</property>
                        <property name="text" translatable="yes">Enable SDR</property>
                        <layout manager="pack">
                          <property name="padx">10 5</property>
                          <property name="side">left</property>
                        </layout>
                        <child>
                          <object class="pygubu.widgets.Tooltip" id="SDR_Enable_Tooltip" named="True">
                            <property name="padx">8</property>
                            <property name="relief">raised</property>
                            <property name="text" translatable="yes">Enable/disable use of external SDR software to provide a Panadapter.</property>
                            <property name="wraplength">300</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Menubutton" id="SDR_Enable_Menubutton" named="True">
                        <property name="style">Heading0.TMenubutton</property>
                        <property name="takefocus">true</property>
                        <property name="textvariable">string:SDR_Enable_VAR</property>
                        <property name="width">5</property>
                        <layout manager="pack">
                          <property name="padx">70 0</property>
                          <property name="side">left</property>
                        </layout>
                        <child>
                          <object class="tk.Menu" id="SDR_Enable_Menu" named="True">
                            <property name="tearoff">false</property>
                            <child>
                              <object class="tk.Menuitem.Command" id="selectSDR_On_Command" named="True">
                                <property name="command" type="command" cbtype="simple">selectSDR_On_CB</property>
                                <property name="font">{Arial} 24 {}</property>
                                <property name="label" translatable="yes">True</property>
                                <property name="state">normal</property>
                              </object>
                            </child>
                            <child>
                              <object class="tk.Menuitem.Command" id="selectSDR_Off_Command" named="True">
                                <property name="command" type="command" cbtype="simple">selectSDR_Off_CB</property>
                                <property name="font">{Arial} 24 {}</property>
                                <property name="label" translatable="yes">False</property>
                                <property name="state">normal</property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="ttk.Frame" id="sdrSoftwareSelection_Frame" named="True">
                    <property name="height">200</property>
                    <property name="style">Normal.TFrame</property>
                    <property name="width">200</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="columnspan">2</property>
                      <property name="padx">10</property>
                      <property name="pady">10</property>
                      <property name="row">1</property>
                      <property name="sticky">ew</property>
                    </layout>
                    <child>
                      <object class="ttk.Label" id="sdrSoftware_Label" named="True">
                        <property name="state">disabled</property>
                        <property name="style">Heading1b.TLabel</property>
                        <property name="text" translatable="yes">SDR Software</property>
                        <layout manager="grid">
                          <property name="column">0</property>
                          <property name="padx">10 5</property>
                          <property name="pady">5</property>
                          <property name="row">0</property>
                          <property name="sticky">w</property>
                        </layout>
                        <child>
                          <object class="pygubu.widgets.Tooltip" id="sdrSoftware_Tooltip" named="True">
                            <property name="padx">8</property>
                            <property name="relief">raised</property>
                            <property name="text" translatable="yes">Select the external SDR software used. Only sdr++ is tested. Others may work if they support rigctl but they cannot be auto started.</property>
                            <property name="wraplength">300</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Menubutton" id="sdrSoftware_Menubutton" named="True">
                        <property name="style">Heading0.TMenubutton</property>
                        <property name="takefocus">true</property>
                        <property name="textvariable">string:SDR_Enable_VAR</property>
                        <property name="width">5</property>
                        <layout manager="grid">
                          <property name="column">1</property>
                          <property name="padx">43 10</property>
                          <property name="pady">5</property>
                          <property name="row">0</property>
                        </layout>
                        <child>
                          <object class="tk.Menu" id="sdrSoftware_Menu" named="True">
                            <property name="tearoff">false</property>
                            <child>
                              <object class="tk.Menuitem.Command" id="sdrplusplus_Menuitem" named="True">
                                <property name="command" type="command" cbtype="simple">selectSDRPlusPlus_CB</property>
                                <property name="font">{Arial} 24 {}</property>
                                <property name="label" translatable="yes">sdr++</property>
                                <property name="state">normal</property>
                              </object>
                            </child>
                            <child>
                              <object class="tk.Menuitem.Command" id="other_Menuitem" named="True">
                                <property name="command" type="command" cbtype="simple">selectSDROther_CB</property>
                                <property name="font">{Arial} 24 {}</property>
                                <property name="label" translatable="yes">Other</property>
                                <property name="state">normal</property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Checkbutton" id="autostart_Checkbox" named="True">
                        <property name="offvalue">False</property>
                        <property name="onvalue">True</property>
                        <property name="style">Checkbox1b.TCheckbutton</property>
                        <property name="text" translatable="yes">Autostart</property>
                        <property name="variable">string:autostartSDR_VAR</property>
                        <layout manager="grid">
                          <property name="column">2</property>
                          <property name="padx">75 0</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Frame" id="SDR_Network_Frame" named="True">
                <property name="height">200</property>
                <property name="style">NormalOutline.TFrame</property>
                <property name="width">200</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="columnspan">2</property>
                  <property name="pady">10 0</property>
                  <property name="row">2</property>
                  <property name="sticky">ew</property>
                </layout>
                <child>
                  <object class="ttk.Frame" id="heading_Frame" named="True">
                    <property name="height">200</property>
                    <property name="style">Normal.TFrame</property>
                    <property name="width">200</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="columnspan">2</property>
                      <property name="padx">10</property>
                      <property name="pady">10 0</property>
                      <property name="row">0</property>
                      <property name="sticky">w</property>
                    </layout>
                    <child>
                      <object class="ttk.Label" id="networkAddress_Label" named="True">
                        <property name="state">disabled</property>
                        <property name="style">Heading1b.TLabel</property>
                        <property name="text" translatable="yes">SDR Network Address</property>
                        <layout manager="pack">
                          <property name="anchor">w</property>
                          <property name="side">top</property>
                        </layout>
                        <child>
                          <object class="pygubu.widgets.Tooltip" id="networkAddress_Tooltip" named="True">
                            <property name="padx">8</property>
                            <property name="relief">raised</property>
                            <property name="text" translatable="yes">Match the entries here to the SDR++ settings under the Module Manager for Rigctl Server</property>
                            <property name="wraplength">300</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Label" id="networkAddressSuggestion_Label" named="True">
                        <property name="style">Heading2bi.TLabel</property>
                        <property name="text" translatable="yes">Usually 127.0.0.1 or localhost with port 4532 or 4533 (less common)</property>
                        <property name="width">60</property>
                        <layout manager="pack">
                          <property name="side">left</property>
                        </layout>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="ttk.Frame" id="address_Frame" named="True">
                    <property name="height">200</property>
                    <property name="style">Normal.TFrame</property>
                    <property name="width">200</property>
                    <layout manager="grid">
                      <property name="padx">200</property>
                      <property name="pady">20</property>
                      <property name="row">1</property>
                    </layout>
                    <child>
                      <object class="ttk.Label" id="ipAddress_Label" named="True">
                        <property name="state">disabled</property>
                        <property name="style">Heading1b.TLabel</property>
                        <property name="text" translatable="yes">Network address:</property>
                        <layout manager="pack" />
                        <child>
                          <object class="pygubu.widgets.Tooltip" id="ipAddress_Tooltip" named="True">
                            <property name="padx">8</property>
                            <property name="relief">raised</property>
                            <property name="text" translatable="yes">Try first 127.0.0.1, then the text localhost and last resort 0.0.0.0</property>
                            <property name="wraplength">300</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="pygubu.widgets.Tooltip" id="tooltip2" named="True">
                        <property name="padx">8</property>
                        <property name="relief">raised</property>
                        <property name="text" translatable="yes">Try first 127.0.0.1, then the text localhost and last resort 0.0.0.0</property>
                        <property name="wraplength">300</property>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Entry" id="ipAddress_Entry" named="True">
                        <property name="font">{Arial} 24 {}</property>
                        <property name="justify">right</property>
                        <property name="takefocus">true</property>
                        <property name="text" translatable="yes">127.0.0.1</property>
                        <property name="textvariable">string:PWR_Factor_VAR</property>
                        <property name="width">8</property>
                        <layout manager="pack" />
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Label" id="port_Label" named="True">
                        <property name="state">disabled</property>
                        <property name="style">Heading1b.TLabel</property>
                        <property name="text" translatable="yes">Port:</property>
                        <layout manager="pack">
                          <property name="pady">10 0</property>
                        </layout>
                        <child>
                          <object class="pygubu.widgets.Tooltip" id="port_Tooltip" named="True">
                            <property name="padx">8</property>
                            <property name="relief">raised</property>
                            <property name="text" translatable="yes">Check SDR++ Module Manager/Rigel Server entry. Typically 4532 or perghaps 4533.</property>
                            <property name="wraplength">300</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="pygubu.widgets.Tooltip" id="tooltip3" named="True">
                        <property name="padx">8</property>
                        <property name="relief">raised</property>
                        <property name="text" translatable="yes">Check SDR++ Module Manager/Rigel Server entry. Typically 4532 or perhaps 4533.</property>
                        <property name="wraplength">300</property>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Entry" id="port_Entry" named="True">
                        <property name="font">{Arial} 24 {}</property>
                        <property name="justify">right</property>
                        <property name="takefocus">true</property>
                        <property name="text" translatable="yes">4532</property>
                        <property name="textvariable">string:SWR_Factor_VAR</property>
                        <property name="width">5</property>
                        <layout manager="pack" />
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="ttk.Frame" id="test_Frame" named="True">
                    <property name="height">200</property>
                    <property name="style">Normal.TFrame</property>
                    <property name="width">200</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="padx">30</property>
                      <property name="pady">20</property>
                      <property name="row">2</property>
                    </layout>
                    <child>
                      <object class="ttk.Button" id="test_Button" named="True">
                        <property name="command" type="command" cbtype="simple">sdrTest_CB</property>
                        <property name="compound">top</property>
                        <property name="style">Button1bARaised.TButton</property>
                        <property name="text" translatable="yes">Test SDR
  Startup</property>
                        <property name="textvariable">string:testButton_CB</property>
                        <layout manager="grid">
                          <property name="column">0</property>
                          <property name="padx">100 20</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Label" id="testMessage_Label" named="True">
                        <property name="style">Heading2bi.TLabel</property>
                        <property name="text" translatable="yes">Success!</property>
                        <property name="textvariable">string:testMessage_VAR</property>
                        <layout manager="grid">
                          <property name="column">1</property>
                          <property name="row">0</property>
                        </layout>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Frame" id="SDR_Options_Frame" named="True">
                <property name="height">200</property>
                <property name="style">NormalOutline.TFrame</property>
                <property name="width">200</property>
                <layout manager="grid">
                  <property name="column">0</property>
                  <property name="columnspan">2</property>
                  <property name="pady">10</property>
                  <property name="row">4</property>
                  <property name="sticky">ew</property>
                </layout>
                <child>
                  <object class="ttk.Frame" id="sdrOptionsHeading_Label" named="True">
                    <property name="height">200</property>
                    <property name="style">Normal.TFrame</property>
                    <property name="width">200</property>
                    <layout manager="grid">
                      <property name="column">0</property>
                      <property name="columnspan">2</property>
                      <property name="padx">10</property>
                      <property name="pady">10</property>
                      <property name="row">0</property>
                      <property name="sticky">w</property>
                    </layout>
                    <child>
                      <object class="ttk.Label" id="sdrOptions_Label" named="True">
                        <property name="state">disabled</property>
                        <property name="style">Heading1b.TLabel</property>
                        <property name="text" translatable="yes">SDR Options</property>
                        <layout manager="pack">
                          <property name="anchor">w</property>
                          <property name="side">top</property>
                        </layout>
                        <child>
                          <object class="pygubu.widgets.Tooltip" id="tooltip6" named="True">
                            <property name="padx">8</property>
                            <property name="relief">raised</property>
                            <property name="text" translatable="yes">Match the entries here to the SDR++ settings under the Module Manager for Rigctl Server</property>
                            <property name="wraplength">300</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Button" id="button1" named="True">
                        <property name="command" type="command" cbtype="simple">sdrTest_CB</property>
                        <property name="compound">top</property>
                        <property name="style">Button1bARaised.TButton</property>
                        <property name="text" translatable="yes">Default Filter
Bandwidth</property>
                        <property name="width">11</property>
                        <layout manager="pack">
                          <property name="padx">30 0</property>
                          <property name="pady">10</property>
                          <property name="side">left</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Button" id="button2" named="True">
                        <property name="command" type="command" cbtype="simple">sdrTest_CB</property>
                        <property name="compound">top</property>
                        <property name="style">Button1bARaised.TButton</property>
                        <property name="text" translatable="yes">Channel and
Note Files</property>
                        <property name="width">11</property>
                        <layout manager="pack">
                          <property name="padx">20 0</property>
                          <property name="pady">10</property>
                          <property name="side">left</property>
                        </layout>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Button" id="button3" named="True">
                        <property name="command" type="command" cbtype="simple">sdrTest_CB</property>
                        <property name="compound">top</property>
                        <property name="style">Button1bARaised.TButton</property>
                        <property name="text" translatable="yes">Channel
Manager</property>
                        <property name="textvariable">string:testButton_CB</property>
                        <property name="width">11</property>
                        <layout manager="pack">
                          <property name="padx">20 0</property>
                          <property name="pady">10</property>
                          <property name="side">left</property>
                        </layout>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="ttk.Frame" id="closingFrame" named="True">
            <property name="height">50</property>
            <property name="style">Normal.TFrame</property>
            <property name="width">200</property>
            <layout manager="pack">
              <property name="anchor">center</property>
              <property name="expand">false</property>
              <property name="pady">20 10</property>
              <property name="side">top</property>
            </layout>
            <child>
              <object class="ttk.Button" id="apply_Button" named="True">
                <property name="command" type="command" cbtype="simple">apply_CB</property>
                <property name="style">Button2b.TButton</property>
                <property name="takefocus">true</property>
                <property name="text" translatable="yes">Apply</property>
                <layout manager="pack">
                  <property name="anchor">center</property>
                  <property name="padx">10</property>
                  <property name="side">left</property>
                </layout>
                <child>
                  <object class="pygubu.widgets.Tooltip" id="apply_Button_Tooltip" named="True">
                    <property name="padx">8</property>
                    <property name="relief">raised</property>
                    <property name="text" translatable="yes">Updates the setting and closes the window.</property>
                    <property name="wraplength">300</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Button" id="cancel_Buttom" named="True">
                <property name="command" type="command" cbtype="simple">cancel_CB</property>
                <property name="style">Button2b.TButton</property>
                <property name="takefocus">true</property>
                <property name="text" translatable="yes">Cancel</property>
                <layout manager="pack">
                  <property name="anchor">center</property>
                  <property name="padx">10</property>
                  <property name="side">left</property>
                </layout>
                <child>
                  <object class="pygubu.widgets.Tooltip" id="cancel_Button_Tooltip" named="True">
                    <property name="padx">8</property>
                    <property name="relief">raised</property>
                    <property name="text" translatable="yes">Exit without writing any changes.</property>
                    <property name="wraplength">300</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
