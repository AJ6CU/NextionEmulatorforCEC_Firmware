<?xml version='1.0' encoding='utf-8'?>
<interface version="1.3">
  <object class="ttk.Frame" id="main_frame">
    <property name="height">650</property>
    <property name="width">850</property>
    <layout manager="pack">
      <property name="expand">true</property>
      <property name="fill">both</property>
    </layout>
    <child>
      <object class="ttk.Notebook" id="notebook">
        <layout manager="pack">
          <property name="expand">true</property>
          <property name="fill">both</property>
          <property name="padx">10</property>
          <property name="pady">10</property>
        </layout>
        <child type="tab">
          <object class="ttk.Frame" id="tab1">
            <property name="padding">15</property>
            <child>
              <object class="ttk.Labelframe" id="lbl_frame_connection">
                <property name="text"> Hardware Interconnect Profiles </property>
                <layout manager="grid"><property name="column">0</property><property name="row">0</property><property name="padx">10</property><property name="pady">10</property></layout>
                <child>
                  <object class="ttk.Label" id="lbl_ip">
                    <property name="text">Radio IP Target Address:</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">0</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Entry" id="ent_radio_ip">
                    <layout manager="grid"><property name="column">1</property><property name="row">0</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="lbl_port">
                    <property name="text">TCP Socket Port:</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">1</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Entry" id="ent_radio_port">
                    <layout manager="grid"><property name="column">1</property><property name="row">1</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="btn_connect">
                    <property name="text">Establish SDR Connection Link</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">2</property><property name="columnspan">2</property><property name="pady">10</property></layout>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Labelframe" id="lbl_frame_telemetry">
                <property name="text"> Live Telemetry Tracker Panel </property>
                <layout manager="grid"><property name="column">0</property><property name="row">1</property><property name="padx">10</property><property name="pady">10</property></layout>
                <child>
                  <object class="ttk.Label" id="lbl_live_freq">
                    <property name="text">Active VFO Frequency:</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">0</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="lbl_val_freq">
                    <property name="text">000.0000 MHz</property>
                    <property name="font">TkFixedFont</property>
                    <layout manager="grid"><property name="column">1</property><property name="row">0</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="lbl_live_mode">
                    <property name="text">Demodulation Mode:</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">1</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="lbl_val_mode">
                    <property name="text">UNKNOWN</property>
                    <layout manager="grid"><property name="column">1</property><property name="row">1</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="lbl_smeter_txt">
                    <property name="text">Signal Strength (dBFS):</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">2</property><property name="padx">5</property><property name="pady">10</property><property name="sticky">w</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Frame" id="smeter_container">
                    <layout manager="grid"><property name="column">1</property><property name="row">2</property><property name="padx">5</property><property name="pady">5</property><property name="sticky">w</property></layout>
                    <child>
                      <object class="ttk.Label" id="lbl_smeter_ticks">
                        <property name="text">S1 . S3 . S5 . S7 . S9 . +10 . +30</property>
                        <property name="font">TkFixedFont</property>
                        <layout manager="pack"><property name="side">top</property><property name="anchor">w</property></layout>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Progressbar" id="smeter_bar">
                        <property name="length">210</property>
                        <property name="maximum">100</property>
                        <property name="mode">determinate</property>
                        <layout manager="pack"><property name="side">top</property><property name="fill">x</property><property name="pady">4</property></layout>
                      </object>
                    </child>
                    <child>
                      <object class="ttk.Label" id="lbl_smeter_val">
                        <property name="text">-00.0 dBFS</property>
                        <property name="font">TkFixedFont</property>
                        <layout manager="pack"><property name="side">top</property><property name="anchor">w</property><property name="pady">2</property></layout>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Labelframe" id="lbl_frame_volume">
                <property name="text"> Receiver Audio Gain Control </property>
                <layout manager="grid"><property name="column">0</property><property name="row">2</property><property name="padx">10</property><property name="pady">10</property><property name="sticky">ew</property></layout>
                <child>
                  <object class="ttk.Label" id="lbl_volume_txt">
                    <property name="text">Audio Volume (0-100):</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">0</property><property name="padx">5</property><property name="pady">10</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Scale" id="scale_volume">
                    <property name="from_">0</property>
                    <property name="to">100</property>
                    <property name="orient">horizontal</property>
                    <property name="length">150</property>
                    <layout manager="grid"><property name="column">1</property><property name="row">0</property><property name="padx">5</property><property name="pady">10</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="lbl_volume_val">
                    <property name="text">50%</property>
                    <property name="font">TkFixedFont</property>
                    <layout manager="grid"><property name="column">2</property><property name="row">0</property><property name="padx">5</property><property name="pady">10</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="btn_mute_toggle">
                    <property name="text">🔊 Mute Audio</property>
                    <layout manager="grid"><property name="column">3</property><property name="row">0</property><property name="padx">10</property><property name="pady">10</property></layout>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child type="tab_properties">
          <property name="text"> SDR Configs &amp; Telemetry </property>
        </child>
        <child type="tab">
          <object class="ttk.Frame" id="tab2">
            <property name="padding">10</property>
            <child>
              <object class="ttk.Frame" id="grid_wrapper">
                <layout manager="grid"><property name="column">0</property><property name="row">0</property><property name="rowspan">8</property><property name="padx">5</property></layout>
                <child>
                  <object class="ttk.Treeview" id="tree_channels">
                    <property name="height">15</property>
                    <property name="selectmode">browse</property>
                    <property name="show">tree headings</property>
                    <layout manager="pack"><property name="side">left</property><property name="fill">both</property><property name="expand">true</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Scrollbar" id="tree_scroll">
                    <property name="orient">vertical</property>
                    <layout manager="pack"><property name="side">right</property><property name="fill">y</property></layout>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="lbl_ch_name">
                <property name="text">New Channel Label:</property>
                <layout manager="grid"><property name="column">1</property><property name="row">0</property><property name="sticky">w</property><property name="padx">5</property><property name="pady">2</property></layout>
              </object>
            </child>
            <child>
              <object class="ttk.Entry" id="ent_label">
                <layout manager="grid"><property name="column">2</property><property name="row">0</property><property name="padx">5</property><property name="pady">2</property></layout>
              </object>
            </child>
            <child>
              <object class="ttk.Label" id="lbl_ch_desc">
                <property name="text">Custom Station Name:</property>
                <layout manager="grid"><property name="column">1</property><property name="row">1</property><property name="sticky">w</property><property name="padx">5</property><property name="pady">2</property></layout>
              </object>
            </child>
            <child>
              <object class="ttk.Entry" id="ent_desc">
                <layout manager="grid"><property name="column">2</property><property name="row">1</property><property name="padx">5</property><property name="pady">2</property></layout>
              </object>
            </child>
            <child>
              <object class="ttk.Button" id="btn_add_channel">
                <property name="text">💾 Capture Live VFO to Channel</property>
                <layout manager="grid"><property name="column">1</property><property name="row">2</property><property name="columnspan">2</property><property name="pady">5</property><property name="sticky">ew</property></layout>
              </object>
            </child>
            <child>
              <object class="ttk.Labelframe" id="lbl_frame_search">
                <property name="text"> Dynamic Channel Lookup Search Engine </property>
                <layout manager="grid"><property name="column">1</property><property name="row">3</property><property name="columnspan">2</property><property name="pady">5</property><property name="sticky">ew</property></layout>
                <child>
                  <object class="ttk.Entry" id="ent_search">
                    <layout manager="grid"><property name="column">0</property><property name="row">0</property><property name="padx">5</property><property name="pady">5</property><property name="sticky">ew</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="btn_delete">
                    <property name="text"> Erase Selected Channel</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">1</property><property name="padx">5</property><property name="pady">2</property><property name="sticky">ew</property></layout>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Labelframe" id="lbl_frame_bank_routing">
                <property name="text"> Cross-Bank Assignment Matrix </property>
                <layout manager="grid"><property name="column">1</property><property name="row">4</property><property name="columnspan">2</property><property name="pady">5</property><property name="sticky">ew</property></layout>
                <child>
                  <object class="ttk.Button" id="btn_new_bank">
                    <property name="text">📋 Create Brand New Bank</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">0</property><property name="columnspan">2</property><property name="padx">4</property><property name="pady">4</property><property name="sticky">ew</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="lbl_src_bank">
                    <property name="text">Source Bank View:</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">1</property><property name="padx">5</property><property name="pady">2</property><property name="sticky">w</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Combobox" id="combobox_sets">
                    <layout manager="grid"><property name="column">1</property><property name="row">1</property><property name="padx">5</property><property name="pady">2</property><property name="sticky">ew</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="lbl_tgt_bank">
                    <property name="text">Target Bank Copy:</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">2</property><property name="padx">5</property><property name="pady">2</property><property name="sticky">w</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Combobox" id="combobox_target_sets">
                    <layout manager="grid"><property name="column">1</property><property name="row">2</property><property name="padx">5</property><property name="pady">2</property><property name="sticky">ew</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="btn_add_to_bank">
                    <property name="text">➕ Copy Row to Target Bank</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">3</property><property name="columnspan">2</property><property name="padx">4</property><property name="pady">4</property><property name="sticky">ew</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="btn_clone_bank">
                    <property name="text">📋 Clone Source to Target Bank</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">4</property><property name="columnspan">2</property><property name="padx">4</property><property name="pady">4</property><property name="sticky">ew</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="btn_delete_bank">
                    <property name="text">🗑️ Erase Current SOURCE Bank</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">5</property><property name="columnspan">2</property><property name="padx">4</property><property name="pady">4</property><property name="sticky">ew</property></layout>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Labelframe" id="lbl_frame_scanner">
                <property name="text"> Memory Scanning Engine </property>
                <layout manager="grid"><property name="column">1</property><property name="row">6</property><property name="columnspan">2</property><property name="pady">10</property></layout>
                <child>
                  <object class="ttk.Button" id="btn_start_scan">
                    <property name="text">▶ Start Scan Loop</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">0</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="btn_stop_scan">
                    <property name="text">⏹ Stop Scan Loop</property>
                    <layout manager="grid"><property name="column">1</property><property name="row">0</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child type="tab_properties">
          <property name="text"> Memory Matrix &amp; Scanning </property>
        </child>
        <child type="tab">
          <object class="ttk.Frame" id="tab3">
            <property name="padding">15</property>
            <child>
              <object class="ttk.Labelframe" id="lbl_frame_timers">
                <property name="text"> System Delays &amp; Calibration Tools </property>
                <layout manager="grid"><property name="column">0</property><property name="row">0</property><property name="padx">10</property><property name="pady">10</property></layout>
                <child>
                  <object class="ttk.Label" id="lbl_delay">
                    <property name="text">Scan Delay Period (ms):</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">0</property><property name="padx">5</property><property name="pady">10</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Entry" id="ent_scan_time">
                    <layout manager="grid"><property name="column">1</property><property name="row">0</property><property name="padx">5</property><property name="pady">10</property></layout>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Labelframe" id="lbl_frame_band_changer">
                <property name="text"> Ham Radio RF Band Changer Matrix </property>
                <layout manager="grid"><property name="column">0</property><property name="row">1</property><property name="padx">10</property><property name="pady">10</property></layout>
                <child>
                  <object class="ttk.Button" id="btn_band_80m">
                    <property name="text">80 Meters (3.5 MHz)</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">0</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="btn_band_40m">
                    <property name="text">40 Meters (7.0 MHz)</property>
                    <layout manager="grid"><property name="column">1</property><property name="row">0</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="btn_band_20m">
                    <property name="text">20 Meters (14.0 MHz)</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">1</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="btn_band_2m">
                    <property name="text">2 Meters (144.2 MHz)</property>
                    <layout manager="grid"><property name="column">1</property><property name="row">1</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="ttk.Labelframe" id="lbl_frame_filter_tools">
                <property name="text"> IF Filter &amp; Bandwidth Management </property>
                <layout manager="grid"><property name="column">0</property><property name="row">2</property><property name="padx">10</property><property name="pady">10</property></layout>
                <child>
                  <object class="ttk.Button" id="btn_filter_widen">
                    <property name="text"> Widen Filter</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">0</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="btn_filter_narrow">
                    <property name="text"> Narrow Filter</property>
                    <layout manager="grid"><property name="column">1</property><property name="row">0</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="btn_filter_reset">
                    <property name="text"> Reset Filter</property>
                    <layout manager="grid"><property name="column">2</property><property name="row">0</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Label" id="lbl_force_bw">
                    <property name="text">Force BW (Hz):</property>
                    <layout manager="grid"><property name="column">0</property><property name="row">1</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Entry" id="ent_force_bw">
                    <layout manager="grid"><property name="column">1</property><property name="row">1</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
                <child>
                  <object class="ttk.Button" id="btn_force_bw">
                    <property name="text">Force Override</property>
                    <layout manager="grid"><property name="column">2</property><property name="row">1</property><property name="padx">5</property><property name="pady">5</property></layout>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child type="tab_properties">
          <property name="text"> System Controls </property>
        </child>
      </object>
    </child>
  </object>
</interface>
